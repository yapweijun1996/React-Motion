# Copy this file to .env.local for local-only development secrets.
# Do not commit .env.local.

# Live tests and helper scripts read these values via Vite loadEnv('test', ...).
# Either pair works; the DEVELOPMENT_* keys are checked first.

DEVELOPMENT_GEMINI_API_KEY=
DEVELOPMENT_GEMINI_MODEL=gemini-3-flash-preview

GEMINI_API_KEY_FOR_DEVELOPMENT_ONLY=
GEMINI_MODEL_FOR_DEVELOPMENT_ONLY=gemini-3-flash-preview

