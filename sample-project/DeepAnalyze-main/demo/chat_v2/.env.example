# Code execution mode: local or docker
DEEPANALYZE_EXECUTION_MODE=local

# Per-run execution timeout in seconds
DEEPANALYZE_EXECUTION_TIMEOUT_SEC=120

# Docker execution settings
# Note: the system does not auto-build the Docker image.
# Before using docker mode for the first time, run this in demo/chat_v2:
# docker build -t deepanalyze-chat-exec:latest -f Dockerfile.exec .
DEEPANALYZE_DOCKER_IMAGE=deepanalyze-chat-exec:latest

# Prefix used for per-session container names
DEEPANALYZE_DOCKER_CONTAINER_NAME=deepanalyze-chat-exec
DEEPANALYZE_DOCKER_SESSION_IDLE_TTL_SEC=1800
DEEPANALYZE_DOCKER_WORKSPACE_DIR=/workspace
DEEPANALYZE_DOCKER_PYTHON_BIN=python
DEEPANALYZE_DOCKER_STOP_ON_SHUTDOWN=true

# Optional: force a CJK main font for PDF export (used when report contains Chinese)
# DEEPANALYZE_PDF_CJK_MAINFONT=SimHei
